# Local dev: MUST be PostgreSQL (schema no longer supports file:./dev.db SQLite)
# Copy from Vercel: npx vercel env pull .env.production.local && npm run dev:env
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
# Direct URL for migrations (Neon on Vercel auto-injects this)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

SESSION_SECRET="change-me-to-a-long-random-string"

OCR_CONFIDENCE_THRESHOLD="70"
DEFAULT_UNIT_PRICE="15000"

# Local: storage | Vercel (tu dong dung /tmp): co the de storage — code se map sang /tmp/storage
STORAGE_DIR="storage"

GOOGLE_SHEETS_ENABLED="false"

# OCR — Roboflow Workflow (Deploy Workflow → Serverless API), xem docs/OCR_MODEL_COLAB.md
METER_DETECT_ENABLED="false"
ROBOFLOW_API_KEY=""
ROBOFLOW_WORKSPACE="duongs-workspace-41kha"
ROBOFLOW_WORKFLOW_ID="detect-count-and-visualize"
# Hoặc URL đầy đủ (ưu tiên hơn workspace+id):
# ROBOFLOW_WORKFLOW_URL="https://serverless.roboflow.com/infer/workflows/duongs-workspace-41kha/detect-count-and-visualize"
ROBOFLOW_DETECT_CLASS=""
# API Detect cũ (chỉ dùng nếu không dùng Workflow):
# ROBOFLOW_DETECT_URL="https://detect.roboflow.com/your-workspace/water-meters/1"
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_SHEET_ID=""
